  "info": {
    "_postman_id": "a06f5fbc-d465-405c-be06-f15fbfb81553",
    "name": "GoldRush Hyperliquid Info API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Drop-in replacement for the public Hyperliquid `/info` endpoint hosted at `hypercore.goldrushdata.com`. The API uses a single POST endpoint that dispatches by the request body's `type` discriminator. Supports 18 info types covering clearinghouse state, spot clearinghouse state, asset contexts, frontend orders, user fills, funding history, ledger updates, delegator history/rewards/summary, sub-accounts, outcome meta, and TWAP slice fills.\n\n\nContact Support:\n Name: GoldRush Support",
      "type": "text/plain"
    }
  }
