              "raw": "{\n  \"type\": \"<string>\",\n  \"user\": \"<string>\",\n  \"users\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"startTime\": \"<long>\",\n  \"endTime\": \"<long>\",\n  \"coin\": \"<string>\"\n}",
