  "info": {
    "_postman_id": "4936c7d2-b983-40c4-9961-535b0cf02b0a",
    "name": "GoldRush Streaming API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "GraphQL-over-WebSocket interface for sub-second blockchain events. Exposes one-shot queries (OHLCV pairs/tokens, token search, top trader wallets, wallet PnL) and live subscriptions (new DEX pairs, OHLCV pairs/tokens, update pairs/tokens, wallet activity). Documented here as a single REST GraphQL endpoint; subscriptions upgrade the same path to WebSocket.\n\n\nContact Support:\n Name: GoldRush Support",
      "type": "text/plain"
    }
  }
